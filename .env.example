# Database
DATABASE_URL="file:./dev.db"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Stripe (get from https://dashboard.stripe.com/test/apikeys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# PayPal (get from https://developer.paypal.com/)
NEXT_PUBLIC_PAYPAL_CLIENT_ID="..."
PAYPAL_CLIENT_SECRET="..."

# Cryptocurrency (configure your receiving wallets)
OWNER_BTC_WALLET="your-btc-wallet-address"
OWNER_ETH_WALLET="your-eth-wallet-address"
OWNER_USDT_WALLET="your-usdt-wallet-address"

# Bank Transfer Details
BANK_NAME="Your Bank Name"
BANK_ACCOUNT_NAME="Your Company Name"
BANK_ACCOUNT_NUMBER="1234567890"
BANK_ROUTING_NUMBER="987654321"
BANK_SWIFT="YOURBANKXXX"

# Email (SMTP - Gmail, Outlook, or use Resend)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="Paula's Place <noreply@paulasplace.com>"

# Admin Dashboard
ADMIN_PASSWORD="changeme123"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
